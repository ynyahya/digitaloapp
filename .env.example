# ── Database ────────────────────────────────────────────────────────────
# Sprint 1 default: SQLite local. Switch provider + URL for Postgres in Sprint 2:
#   DATABASE_URL="postgresql://user:pass@host:5432/digitalo?schema=public"
DATABASE_URL="file:./dev.db"

# ── NextAuth (Auth.js v5) ───────────────────────────────────────────────
# Generate: `openssl rand -base64 32`
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Magic-link email provider (Resend). Leave empty in dev — NextAuth prints the link to the console.
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Digitalo <noreply@digitalo.app>"

# ── Stripe ──────────────────────────────────────────────────────────────
# Test keys are fine for dev; switch to live keys only in production.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
